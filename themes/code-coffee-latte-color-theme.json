  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "comment.line", "comment.block", "punctuation.definition.comment"],
      "settings": { "foreground": "#9E9E9E", "fontStyle": "italic" }
    },
    {
      "name": "Documentation Comments",
      "scope": ["comment.block.documentation", "comment.block.javadoc", "comment.block.documentation storage.type", "comment.block.documentation punctuation.definition"],
      "settings": { "foreground": "#8D6E63", "fontStyle": "italic" }
    },
    {
      "name": "Keywords",
      "scope": ["keyword", "keyword.control", "keyword.control.conditional", "keyword.control.loop", "keyword.control.flow", "keyword.control.trycatch", "keyword.control.switch"],
      "settings": { "foreground": "#B71C1C" }
    },
    {
      "name": "Keyword Operators",
      "scope": [
        "keyword.operator.new", "keyword.operator.expression", "keyword.operator.logical",
        "keyword.operator.delete", "keyword.operator.typeof", "keyword.operator.instanceof",
        "keyword.operator.void", "keyword.operator.in", "keyword.operator.of",
        "keyword.operator.expression.typeof", "keyword.operator.expression.instanceof",
        "keyword.operator.expression.in", "keyword.operator.expression.of",
        "keyword.operator.expression.void", "keyword.operator.expression.delete"
      ],
      "settings": { "foreground": "#B71C1C" }
    },
    {
      "name": "Storage Types",
      "scope": ["storage", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#B71C1C" }
    },
    {
      "name": "Storage Type Function Arrow",
      "scope": ["storage.type.function.arrow"],
      "settings": { "foreground": "#795548" }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator", "keyword.operator.assignment", "keyword.operator.arithmetic",
        "keyword.operator.comparison", "keyword.operator.relational",
        "keyword.operator.bitwise", "keyword.operator.ternary",
        "keyword.operator.spread", "keyword.operator.rest",
        "keyword.operator.type", "keyword.operator.optional"
      ],
      "settings": { "foreground": "#795548" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other", "variable.other.readwrite", "variable.other.object"],
      "settings": { "foreground": "#3E2723" }
    },
    {
      "name": "Variable Properties",
      "scope": ["variable.other.property", "variable.other.object.property", "meta.object-literal.key"],
      "settings": { "foreground": "#795548" }
    },
    {
      "name": "Language Variables (this, self, super)",
      "scope": ["variable.language", "variable.language.this", "variable.language.self", "variable.language.super"],
      "settings": { "foreground": "#B71C1C", "fontStyle": "italic" }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter", "meta.parameter", "variable.parameter.function"],
      "settings": { "foreground": "#3E2723", "fontStyle": "italic" }
    },
    {
      "name": "Constants",
      "scope": [
        "constant", "constant.language", "constant.language.boolean",
        "constant.language.null", "constant.language.undefined",
        "constant.other", "support.constant", "variable.other.constant"
      ],
      "settings": { "foreground": "#E65100" }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric", "constant.numeric.integer", "constant.numeric.float",
        "constant.numeric.hex", "constant.numeric.octal",
        "constant.numeric.binary", "constant.numeric.decimal"
      ],
      "settings": { "foreground": "#F57F17" }
    },
    {
      "name": "Strings",
      "scope": [
        "string", "string.quoted", "string.quoted.single",
        "string.quoted.double", "string.quoted.triple", "string.quoted.other"
      ],
      "settings": { "foreground": "#2E7D32" }
    },
    {
      "name": "Template Strings",
      "scope": ["string.template", "string.quoted.template"],
      "settings": { "foreground": "#2E7D32" }
    },
    {
      "name": "Template Expression Punctuation",
      "scope": ["punctuation.definition.template-expression.begin", "punctuation.definition.template-expression.end"],
      "settings": { "foreground": "#B71C1C" }
    },
    {
      "name": "Escape Characters",
      "scope": ["constant.character.escape"],
      "settings": { "foreground": "#00838F" }
    },
    {
      "name": "Regular Expressions",
      "scope": ["string.regexp"],
      "settings": { "foreground": "#E65100" }
    },
    {
      "name": "Function Declarations",
      "scope": ["entity.name.function", "meta.function-call entity.name.function", "support.function", "meta.function entity.name.function"],
      "settings": { "foreground": "#1565C0" }
    },
    {
      "name": "Method Calls",
      "scope": ["meta.method-call entity.name.function", "entity.name.function.member"],
      "settings": { "foreground": "#1565C0" }
    },
    {
      "name": "Classes",
      "scope": ["entity.name.type.class", "support.class", "entity.other.inherited-class", "entity.name.type"],
      "settings": { "foreground": "#7B1FA2" }
    },
    {
      "name": "Interfaces",
      "scope": ["entity.name.type.interface"],
      "settings": { "foreground": "#7B1FA2", "fontStyle": "italic" }
    },
    {
      "name": "Enums",
      "scope": ["entity.name.type.enum"],
      "settings": { "foreground": "#E65100" }
    },
    {
      "name": "Type Parameters / Generics",
      "scope": ["entity.name.type.parameter"],
      "settings": { "foreground": "#7B1FA2", "fontStyle": "italic" }
    },
    {
      "name": "Type Annotations",
      "scope": ["support.type", "support.type.primitive", "meta.type.annotation entity.name.type"],
      "settings": { "foreground": "#7B1FA2" }
    },
    {
      "name": "Namespaces",
      "scope": ["entity.name.namespace", "entity.name.type.module"],
      "settings": { "foreground": "#3E2723" }
